---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<style is:global>
    .pattern-overlay {
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0l2.598 15L45 17.402 32.598 20 30 35l-2.598-15L15 17.402 27.402 15z' fill='%233f4e2f' fill-opacity='0.05' fill-rule='evenodd'/%3E%3C/svg%3E");
    }
    
    @media (prefers-reduced-motion: no-preference) {
        .reveal-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-up.active {
            opacity: 1;
            transform: translateY(0);
        }
        
        @keyframes soft-pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.9; transform: scale(1.02); }
        }
        .animate-soft-pulse {
            animation: soft-pulse 3s ease-in-out infinite;
        }
        
        .hover-lift {
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
        }
    }
</style>

<main class="pt-24 pb-section-padding-desktop pattern-overlay">
<!-- Hero Section -->
<section class="max-w-container-max mx-auto px-gutter mb-16 text-center reveal-up active">
<h1 class="font-display-lg text-display-lg text-primary mb-4">Artikel &amp; Edukasi</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
                Menyajikan wawasan mendalam seputar parenting Islami, metode pendidikan anak berdasarkan fitrah, dan mutiara hikmah Al-Qur'an untuk membimbing ananda tercinta.
