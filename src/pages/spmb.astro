<a class="text-on-surface text-sm font-medium hover:text-primary transition-colors" href="#">Kontak</a>
</nav>
<div class="flex items-center gap-4"><a href="#" class="flex items-center"><img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvjhUQbvOSmiPDzG6AQgafcrIERU3ykZ9Vs3xdktiaBADpNV00aoBsBGPU6Vh-bkWZMer6DNQMjje2vV0XbzySJQ8fOiI4eJvZr7J4a0umpzHI-lh7TnUiEJ50bOCeB7tinN-gO0JQNxKZ0QlBikBuykeyWTIkVY-2-UUSw_XVBxOZ1G3vfzKuVRAO2XnPMUEsT0UYliFp7DHKr9JJvGzANIN7IYWOu7Yh35sBQ3H0xRjgvXE5fEClgX16D1DGFcCjNKNtc5MJF6A" alt="Tarbiyah Sunnah Lab School Logo" class="h-12 w-auto object-contain"></a></div>
</header>
<main class="flex-1">
<!-- Hero Section -->
<section class="max-w-container-max mx-auto px-6 lg:px-12 py-12 lg:py-20 flex flex-col lg:flex-row gap-12 items-center">
<div class="flex-1 space-y-8 animate-fade-in-up">
<div class="space-y-4">
<span class="text-secondary font-label-caps uppercase tracking-widest bg-secondary-fixed px-3 py-1 rounded-full inline-block">Penerimaan Santri Baru 2024/2025</span>
<h1 class="font-display-lg text-primary text-5xl lg:text-6xl leading-[1.1]">
                            Membangun Generasi <br> Beradab &amp; Berilmu
                        </h1>
<p class="text-body-lg text-on-surface-variant max-w-xl">
                            Bergabunglah bersama kami dalam perjalanan menuntut ilmu syar'i yang berasaskan Al-Qur'an dan As-Sunnah sesuai pemahaman para salafus shalih.
                        </p>
</div>
<div class="flex flex-wrap gap-4">
<button class="bg-primary-container text-on-primary text-lg font-bold px-10 h-14 rounded-full shadow-lg hover:shadow-xl transition-all flex items-center gap-2 hover:-translate-y-1">
                            Mulai Pendaftaran <span class="material-symbols-outlined transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
</button>
<button class="bg-surface-container-high text-on-surface text-lg font-bold px-10 h-14 rounded-full hover:bg-surface-variant transition-all hover:-translate-y-1">
                            Unduh Panduan PDF
                        </button>
</div>
</div>
<div class="flex-1 relative animate-fade-in-up" style="animation-delay: 200ms;">
