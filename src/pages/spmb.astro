---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<div class="relative flex min-h-screen w-full flex-col bg-background">
<!-- Header -->
<header class="flex items-center justify-between border-b border-outline-variant px-6 lg:px-40 py-4 bg-surface-container-lowest sticky top-0 z-50 shadow-sm">
<div class="flex items-center gap-4"><a href="#" class="flex items-center"><img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvjhUQbvOSmiPDzG6AQgafcrIERU3ykZ9Vs3xdktiaBADpNV00aoBsBGPU6Vh-bkWZMer6DNQMjje2vV0XbzySJQ8fOiI4eJvZr7J4a0umpzHI-lh7TnUiEJ50bOCeB7tinN-gO0JQNxKZ0QlBikBuykeyWTIkVY-2-UUSw_XVBxOZ1G3vfzKuVRAO2XnPMUEsT0UYliFp7DHKr9JJvGzANIN7IYWOu7Yh35sBQ3H0xRjgvXE5fEClgX16D1DGFcCjNKNtc5MJF6A" alt="Tarbiyah Sunnah Lab School Logo" class="h-12 w-auto object-contain"></a></div>
<nav class="hidden md:flex items-center gap-9">
