<div class="group relative overflow-hidden rounded-lg shadow-md hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
<img class="w-full aspect-video object-cover transition-transform duration-500 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCTw-Yx2ELPm_DZ24sWUEP5LoTbzuxrfQ060EVCaQUVBSea5SyU3ncbA7apJIqw8Q4pw_u5UJ47cEAYVqTDSHw6aVfG_zqIqVteyhm5Q2FbOM2FbY2HQ1zJ7U0ONRqO5kuQDh0TixHG-S3-2jpBWVFrsn5ePAwVcosRt8oDNUIFZ6C1LHxgAgnBenoQ7DB2b-l_ByVKoMxqEgkyQ7qz8RYt6-iY0qpkejS-MMckHepol-Qe2cIERUuvVFCyMiU9adFJ5LVq_JaepL3rhg">
