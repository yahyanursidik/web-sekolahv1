<div class="flex flex-col sm:flex-row gap-4 justify-center">
<a class="bg-white text-secondary px-8 py-4 rounded-full font-bold hover:bg-surface-bright transition-all scale-95 active:scale-90 flex items-center justify-center gap-2" href="#">
<span class="material-symbols-outlined">how_to_reg</span>
                        Daftar SPMB Online
                    </a>
<a class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold hover:opacity-90 transition-all scale-95 active:scale-90 flex items-center justify-center gap-2" href="#">
<span class="material-symbols-outlined">chat</span>
                        Konsultasi via WhatsApp
