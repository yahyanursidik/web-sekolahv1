<!-- Nilai Pendidikan Section -->
<section class="py-section-padding-desktop container mx-auto px-gutter text-center reveal active">
<h2 class="font-headline-md text-headline-md text-primary mb-12">Nilai-Nilai Dasar Pendidikan</h2>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
<div class="bg-white p-8 rounded-lg shadow-[0px_4px_20px_rgba(63,78,47,0.08)] border border-outline-variant/20 hover:-translate-y-2 hover:shadow-lg transition-all duration-300">
<div class="w-16 h-16 bg-surface-container rounded-full flex items-center justify-center mx-auto mb-6">
<span class="material-symbols-outlined text-primary text-3xl">menu_book</span>
</div>
<h4 class="font-headline-sm text-headline-sm text-primary mb-3">Berbasis Tauhid</h4>
<p class="font-body-md text-on-surface-variant">Menjadikan pengenalan kepada Allah sebagai landasan utama setiap disiplin ilmu.</p>
</div>
<div class="bg-white p-8 rounded-lg shadow-[0px_4px_20px_rgba(63,78,47,0.08)] border border-outline-variant/20 hover:-translate-y-2 hover:shadow-lg transition-all duration-300">
