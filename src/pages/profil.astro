</div>
</div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    if (entry.target.id === 'timeline-container') {
                        document.getElementById('timeline-progress').classList.add('active');
                        const dots = entry.target.querySelectorAll('.timeline-dot');
                        dots.forEach((dot, index) => {
                            setTimeout(() => {
                                dot.classList.add('active');
                            }, (index + 1) * 300);
                        });
                    }
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach((element) => {
            observer.observe(element);
        });
        
        const timelineContainer = document.getElementById('timeline-container');
        if(timelineContainer) observer.observe(timelineContainer);
    });
</script>



</Layout>
